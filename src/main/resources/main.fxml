<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<BorderPane prefHeight="383.0" prefWidth="360.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.TicTacToe.Controller">
   <top>
       <MenuBar BorderPane.alignment="CENTER">
           <Menu mnemonicParsing="false" text="_File">
               <items>
               <MenuItem mnemonicParsing="false" onAction="#requestNewGame" text="New game" />
               <SeparatorMenuItem mnemonicParsing="false" />
                   <MenuItem mnemonicParsing="false" onAction="#importGame" text="Import game" />
                   <MenuItem mnemonicParsing="false" onAction="#exportGame" text="Export game" />
                   <SeparatorMenuItem mnemonicParsing="false" />
                   <MenuItem mnemonicParsing="false" onAction="#close" text="Close" />
               </items>
           </Menu>
           <Menu mnemonicParsing="false" text="_Help">
               <items>
                   <MenuItem mnemonicParsing="false" text="How to play" />
               <SeparatorMenuItem mnemonicParsing="false" />
                   <MenuItem mnemonicParsing="false" text="About" />
               </items>
           </Menu>
       </MenuBar>
   </top>
   <center>
      <GridPane alignment="CENTER" hgap="8.0" maxHeight="360.0" maxWidth="360.0" prefHeight="360.0" prefWidth="360.0" style="-fx-background-color: #222222;" vgap="8.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
        <columnConstraints>
          <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="-Infinity" percentWidth="33.333" />
          <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="-Infinity" percentWidth="33.333" />
            <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="-Infinity" percentWidth="33.333" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="-Infinity" percentHeight="33.333" valignment="CENTER" vgrow="ALWAYS" />
          <RowConstraints minHeight="-Infinity" percentHeight="33.333" valignment="CENTER" vgrow="ALWAYS" />
          <RowConstraints minHeight="-Infinity" percentHeight="33.333" valignment="CENTER" vgrow="ALWAYS" />
        </rowConstraints>
         <children>
            <Button fx:id="btn00" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle00" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn01" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle01" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn02" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle02" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn20" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle20" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.hgrow="ALWAYS" GridPane.rowIndex="2" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn10" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle10" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn21" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle21" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="2" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn11" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle11" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn22" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle22" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.hgrow="ALWAYS" GridPane.rowIndex="2" GridPane.vgrow="ALWAYS" />
            <Button fx:id="btn12" focusTraversable="false" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggle12" style="-fx-background-color: white; -fx-background-radius: 0; -fx-border-width: 0; -fx-font-size: 48px; -fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.vgrow="ALWAYS" />
         </children>
      </GridPane>
   </center>
</BorderPane>
